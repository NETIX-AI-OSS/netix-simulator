FROM rust:1-slim AS build
RUN apt-get update && apt-get install -y --no-install-recommends pkg-config libssl-dev git ca-certificates && rm -rf /var/lib/apt/lists/*
WORKDIR /src
COPY . .
RUN cargo build --locked --release --bin simulator
FROM debian:stable-slim
RUN useradd -u 65532 -m sim
COPY --from=build /src/target/release/simulator /usr/local/bin/simulator
USER sim
ENTRYPOINT ["/usr/local/bin/simulator", "--no-tui", "--config", "/config/config.yaml"]
